{
  "id": "esp32_finder",
  "name": "ESP32 Finder",
  "version": "1.0.0",
  "author": "GhostESP",
  "description": "Find nearby ESP32 and GhostESP WiFi access points.",
  "category": "Tools",
  "entry": "esp32_finder.so",
  "target": "esp32c5",
  "api_version": 1,
  "manifest_version": 1,
  "package_version": 6,
  "data_version": 6,
  "storage_scope": "app",
  "icon": "icon.rgb565",
  "icon_source": "find-svgrepo-com.png",
  "icon_format": "rgb565a8",
  "icon_width": 50,
  "icon_height": 50,
  "accent_color": "#56B6F7",
  "permissions": ["ui", "wifi", "rgb"],
  "memory_limit": 0,
  "stack_size": 8192,
  "requires_psram": false
}
